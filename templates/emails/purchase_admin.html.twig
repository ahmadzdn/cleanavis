{% extends 'emails/layout.html.twig' %}

{% block email_title %}Nouveau paiement — CleanAvis{% endblock %}
{% block heading %}Nouvelle commande payée{% endblock %}

{% block body %}
<p style="margin:0 0 14px;">Une commande vient d’être validée (webhook Stripe).</p>

<table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color:#E8F0FE;border-radius:12px;border:1px solid #DADCE0;margin-bottom:14px;">
  <tr>
    <td style="padding:16px 18px;">
      <p style="margin:0 0 8px;font-size:13px;text-transform:uppercase;letter-spacing:.06em;color:#1A73E8;font-weight:700;">Référence &amp; montant</p>
      <p style="margin:0;font-size:15px;color:#202124;">
        <strong>{{ order.reference }}</strong>
        · Pack : {{ order.packKey }}
        · {% if order.amountTotal is not null %}{{ (order.amountTotal / 100)|number_format(2, ',', ' ') }} €{% else %}—{% endif %}
      </p>
    </td>
  </tr>
</table>

<table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:14px;">
  <tr>
    <td style="padding:4px 0;font-size:14px;color:#5F6368;width:130px;">Client</td>
    <td style="padding:4px 0;font-size:14px;color:#202124;">{{ order.firstName }} {{ order.lastName }}</td>
  </tr>
  <tr>
    <td style="padding:4px 0;font-size:14px;color:#5F6368;">E-mail</td>
    <td style="padding:4px 0;"><a href="mailto:{{ order.email }}" style="color:#1A73E8;font-weight:600;">{{ order.email }}</a></td>
  </tr>
  <tr>
    <td style="padding:4px 0;font-size:14px;color:#5F6368;vertical-align:top;">Entreprise</td>
    <td style="padding:4px 0;font-size:14px;color:#202124;">{{ order.company }}</td>
  </tr>
</table>

<p style="margin:0 0 8px;font-size:13px;text-transform:uppercase;letter-spacing:.06em;color:#5F6368;font-weight:700;">URL de l’avis</p>
<p style="margin:0 0 16px;word-break:break-all;font-size:13px;">
  <a href="{{ order.reviewUrl }}" style="color:#1A73E8;">{{ order.reviewUrl }}</a>
</p>

<p style="margin:0 0 8px;font-size:13px;text-transform:uppercase;letter-spacing:.06em;color:#5F6368;font-weight:700;">Justification / contexte</p>
<div style="background-color:#FBF8F3;border-radius:12px;border:1px solid #DADCE0;padding:14px 16px;color:#202124;font-size:14px;line-height:1.55;">
  {{ order.justification|nl2br }}
</div>
{% endblock %}
