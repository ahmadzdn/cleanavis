{# Gabarit transactionnel — styles inline pour compatibilité messagerie #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  {# Réduit les inversions « mode sombre » qui cassent le contraste #}
  <meta name="color-scheme" content="light">
  <meta name="supported-color-schemes" content="light">
  <title>{% block email_title %}CleanAvis{% endblock %}</title>
</head>
<body style="margin:0;padding:0;background-color:#F8F9FA;-webkit-font-smoothing:antialiased;">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color:#F8F9FA;padding:28px 14px;font-family:'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;">
    <tr>
      <td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px;background-color:#FFFFFF;border-radius:16px;border:1px solid #DADCE0;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);">
          {# bgcolor + fond uni : Apple Mail ignore souvent linear-gradient → texte blanc sur fond blanc #}
          <tr>
            <td bgcolor="#1A73E8" style="background-color:#1A73E8;padding:22px 26px;">
              <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td style="color:#FFFFFF;">
                    <span style="font-size:21px;font-weight:700;color:#FFFFFF;letter-spacing:-0.03em;">CleanAvis</span>
                  </td>
                  <td align="right" style="font-size:12px;color:#E8F0FE;">
                    cleanavis.fr
                  </td>
                </tr>
              </table>
              {% block header_tag %}
              <p style="margin:14px 0 0;font-size:17px;font-weight:600;color:#FFFFFF;line-height:1.35;">
                {% block heading %}{% endblock %}
              </p>
              {% endblock %}
            </td>
          </tr>
          <tr>
            <td style="padding:26px 26px 8px;color:#202124;font-size:15px;line-height:1.65;">
              {% block body %}{% endblock %}
            </td>
          </tr>
          <tr>
            <td style="padding:12px 26px 22px;border-top:1px solid #F1F3F4;font-size:12px;color:#5F6368;line-height:1.5;">
              {% block footer_extra %}
              <p style="margin:0;">CleanAvis.fr — Expertise e-réputation &amp; droit du numérique</p>
              {% endblock %}
            </td>
          </tr>
        </table>
        <p style="margin:18px 8px 0;font-size:11px;color:#80868B;max-width:560px;text-align:center;line-height:1.45;">
          Cet e-mail a été envoyé automatiquement. Pour toute question, utilisez les coordonnées indiquées sur <a href="https://cleanavis.fr" style="color:#1A73E8;">cleanavis.fr</a>.
        </p>
      </td>
    </tr>
  </table>
</body>
</html>
