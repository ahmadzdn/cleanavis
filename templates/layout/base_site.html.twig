<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}CleanAvis.fr{% endblock %}</title>
{% block meta %}{% endblock %}
<link rel="icon" href="{{ asset('favicon.ico') }}" type="image/x-icon">
<meta name="theme-color" content="#1A73E8">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800;900&family=Inter:wght@400;500;600&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
{% block styles %}{% endblock %}
{% block head_extra %}{% endblock %}
</head>
<body{% block body_attr %}{% endblock %}>
{% block body %}{% endblock %}
{% block scripts %}{% endblock %}
</body>
</html>
