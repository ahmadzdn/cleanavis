{% extends 'layout/base_site.html.twig' %}

{% block title %}Paiement annulé — CleanAvis.fr{% endblock %}

{% block seo %}
{% include 'partials/seo_payment_tunnel.html.twig' %}
{% endblock %}

{% block styles %}
<link rel="stylesheet" href="{{ asset('assets/css/payment_pages.css') }}">
{% endblock %}

{% block body %}
<div class="card">
  <div class="icon icon--neutral">
    <svg viewBox="0 0 24 24" fill="none" stroke="#5F6368" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
  </div>

  <h1>Paiement non finalisé</h1>
  <p class="subtitle">Votre paiement a été annulé. Aucun montant n'a été débité de votre compte.</p>

  <div class="reassurance">
    💡 <strong>Votre dossier est sauvegardé.</strong> Vous pouvez reprendre votre demande à tout moment en choisissant à nouveau votre pack sur la page d'accueil.
  </div>

  <a href="{{ path('app_home') }}#contact" class="btn-primary">Reprendre ma demande</a>
  <a href="{{ path('app_home') }}" class="btn-secondary">← Retour à l'accueil</a>
</div>
{% endblock %}
