<section class="expertise" id="fiche-gmb" aria-labelledby="fiche-title" style="background:var(--white);border-top:1px solid var(--border);">
  <div class="container">
    <div class="g4bar" aria-hidden="true"></div>
    <div class="sec-eyebrow" style="color:var(--g-blue)">
