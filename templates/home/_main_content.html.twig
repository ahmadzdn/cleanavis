        <div id="url-err" class="url-err-msg" role="alert">⚠️ Veuillez coller un lien URL valide commençant par https://</div>
        <div id="url-hint" style="font-size:11px;color:var(--text4);margin-top:5px">→ Sur Google Maps : clic droit sur l'avis → "Copier le lien"</div>
        <div id="review-preview" aria-live="polite"></div>
      </div>
        </div>
      </div>

      <div class="contact-step" role="group" aria-labelledby="contact-step-offer">
        <div class="contact-step__header" id="contact-step-offer">
          <span class="contact-step__num" aria-hidden="true">3</span>
          <div class="contact-step__titles">
            <span class="contact-step__kicker">Étape 3</span>
            <span class="contact-step__name">Offre &amp; dossier</span>
          </div>
        </div>
        <div class="contact-step__body">
      <div class="form-group">
        <label for="f-package">Package souhaité</label>
        <select id="f-package" name="package" aria-label="Sélectionnez votre package">
          {% for pack in packOffers %}
          <option value="{{ pack.formSlug }}">{{ pack.cardTitle }} ({{ (pack.priceAmountCents / 100)|round(0, 'common') }} €)</option>
          {% endfor %}
        </select>
      </div>
      <div class="form-group">
        <label for="f-justif">Justification de la demande <span class="req" aria-hidden="true">*</span></label>
        <textarea id="f-justif" name="justification" placeholder="Exposez les motifs de votre demande : pourquoi cet avis est-il diffamatoire, faux ou illicite ? Précisez tout élément utile (identité supposée de l'auteur, contexte, historique...)." required aria-label="Exposé des motifs juridiques"></textarea>
      </div>
      <div class="cf-turnstile" data-sitekey="{{ turnstile_site_key }}" data-theme="light" style="margin-bottom:16px;display:flex;justify-content:center"></div>
      <button class="btn-blue btn-wide" onclick="submitForm()" type="button" aria-label="Envoyer la demande de suppression">
        🔒 Valider ma demande et procéder au paiement
      </button>
      <div class="secure-note" aria-label="Sécurité et confidentialité">
        <div class="secure-icon" aria-hidden="true">🔒</div>
        Données chiffrées · 100% confidentiel · Conforme RGPD · Horodatage automatique
      </div>
        </div>
      </div>

      </div>
    </div>
  </div>
</section>

{% if faqItems is defined and faqItems|length > 0 %}
<!-- FAQ -->
<section class="faq" id="faq" aria-labelledby="faq-title">
  <div class="container">
    <div class="g4bar" aria-hidden="true"></div>
    <div class="sec-eyebrow" style="color:var(--g-blue)">
      <span class="edot" style="background:var(--g-blue)" aria-hidden="true"></span>
      FAQ
    </div>
    <h2 class="sec-title" id="faq-title">Questions <em>fréquentes</em></h2>
    <div class="faq-list">
      {% for item in faqItems %}
      <div class="faq-item reveal">
        <button type="button" class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          {{ item.question }}
          <span class="faq-arrow" aria-hidden="true">▾</span>
        </button>
        <div class="faq-a">{{ item.answer }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

</main>

