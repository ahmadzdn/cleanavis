# Symfony sur EB : document root = sous-dossier public/ ; Composer exécuté par la plateforme (voir composer_options).
# APP_SECRET, DATABASE_URL, clés API : uniquement dans la console EB ou Parameter Store — pas dans ce fichier.
option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    composer_options: '--no-dev --optimize-autoloader --no-scripts'
    memory_limit: 256M
  aws:elasticbeanstalk:application:environment:
    APP_ENV: prod
    APP_DEBUG: '0'
